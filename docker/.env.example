# Copy to .env in this directory before running `docker compose up`.
# Generate the gateway key with: openssl rand -hex 32
PIXELRELAY_GATEWAY_KEY=

# The URL where this gateway is reachable from fal/replicate. They POST callbacks
# back to this URL when jobs complete, so it must be public (or use a tunnel like
# ngrok/cloudflared during development).
PIXELRELAY_PUBLIC_URL=https://your-gateway.example.com

# Provider keys — BYOK. Set at least one.
FAL_KEY=
REPLICATE_API_TOKEN=

# Webhook signature config (recommended for production)
FAL_WEBHOOK_PUBLIC_KEY=
REPLICATE_WEBHOOK_SECRET=

# Secret used to sign webhooks the gateway sends to YOUR app's webhook_url
PIXELRELAY_WEBHOOK_SECRET=
